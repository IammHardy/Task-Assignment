<%# FLASH MESSAGES %>
<% if flash[:notice] %>
  <div class="mb-4 p-3 bg-green-100 text-green-800 border border-green-300 rounded">
    <%= flash[:notice] %>
  </div>
<% elsif flash[:alert] %>
  <div class="mb-4 p-3 bg-red-100 text-red-800 border border-red-300 rounded">
    <%= flash[:alert] %>
  </div>
<% end %>

<%# VIEW SWITCH LINKS %>
<div class="mb-4 p-3 border rounded flex space-x-2 items-center">
  <%= link_to "Admin", dashboard_index_path(view: "admin"), class: "px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
  <%= link_to "Manager", dashboard_index_path(view: "manager"), class: "px-3 py-2 bg-green-600 text-white rounded hover:bg-green-700" %>
  <%= link_to "Employee", dashboard_index_path(view: "employee"), class: "px-3 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600" %>

  <%# --- Manager / Employee selector --- %>
  <% if @active_view == "manager" %>
    <%= turbo_frame_tag "manager_selector" do %>
      <%= form_with url: dashboard_index_path, method: :get, local: false, data: { turbo_frame: "tasks-table" } do %>
        <%= hidden_field_tag :view, "manager" %>
        <%= select_tag :manager_id,
            options_from_collection_for_select(@managers, :id, :name, @active_manager&.id),
            class: "ml-2 border rounded px-2 py-1",
            onchange: "this.form.submit();" %>
      <% end %>
    <% end %>
  <% elsif @active_view == "employee" %>
    <%= turbo_frame_tag "employee_selector" do %>
      <%= form_with url: dashboard_index_path, method: :get, local: false, data: { turbo_frame: "tasks-table" } do %>
        <%= hidden_field_tag :view, "employee" %>
        <%= select_tag :employee_id,
            options_from_collection_for_select(@employees, :id, :name, @active_employee&.id),
            class: "ml-2 border rounded px-2 py-1",
            onchange: "this.form.submit();" %>
      <% end %>
    <% end %>
  <% end %>
</div>

<%# --- CREATE TASK FORM (Admin/Manager) --- %>
<% if @active_view.in?(%w[admin manager]) %>
  <div class="mb-6 p-4 border rounded bg-gray-50">
    <h3 class="text-lg font-semibold mb-2">Create New Task</h3>

    <turbo-frame id="task-form">
      <%= render "tasks/form",
          task: Task.new,
          employees: (@active_view == "manager" && @active_manager ? @employees.where(manager_id: @active_manager.id) : @employees),
          managers: @managers,
          active_view: @active_view %>
    </turbo-frame>

    <turbo-frame id="task-msg"></turbo-frame>
  </div>
<% end %>

<%# --- TASKS TABLE --- %>

<turbo-frame id="tasks-table">
  <%= render "dashboard/tasks_table",
      tasks_to_show: @tasks_to_show,
      active_view: @active_view,
      current_user: @current_user,
      active_employee: @active_employee,
      active_manager: @active_manager,
      employees: @employees,
      managers: @managers %>
</turbo-frame>

<%# --- AI Summary --- %>
<div id="ai_summary_frame" class="mt-4 p-3 border rounded bg-gray-50">
  <%= @ai_summary if defined?(@ai_summary) %>
</div>