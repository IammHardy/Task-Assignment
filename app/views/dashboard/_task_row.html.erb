<turbo-frame id="task_<%= task.id %>">
<tr class="border-b hover:bg-gray-50">

  <!-- Title -->
  <td class="px-4 py-2 border">
    <%= task.title %>
    <% if task.description.present? %>
      <div class="text-sm text-gray-500"><%= task.description %></div>
    <% end %>
  </td>

  <!-- Assigned Employee -->
  <td class="px-4 py-2 border">
    <%= task.user&.name || "Unassigned" %>
  </td>

  <!-- Status -->
  <td class="px-4 py-2 border">
    <span class="px-2 py-1 rounded text-white
      <%= case task.status
          when "completed" then "bg-green-500"
          when "in_progress" then "bg-yellow-500"
          else "bg-gray-500"
          end %>">
      <%= task.status.humanize %>
    </span>
  </td>

  <!-- Priority -->
  <td class="px-4 py-2 border">
    <span class="px-2 py-1 rounded text-white
      <%= case task.priority
          when "high" then "bg-red-500"
          when "medium" then "bg-yellow-500"
          else "bg-green-500"
          end %>">
      <%= task.priority.humanize %>
    </span>
  </td>

  <!-- Due Date -->
  <td class="px-4 py-2 border">
    <%= task.due_date ? task.due_date.strftime("%d %b %Y") : "-" %>
  </td>

  <!-- Documents -->
  <td class="px-4 py-2 border">
    <% if task.files.attached? %>
      <% task.files.each do |file| %>
        <div>
          <%= link_to file.filename, url_for(file),
              class: "text-blue-600 underline",
              target: "_blank" %>
        </div>
      <% end %>
    <% else %>
      <span class="text-gray-400">No files</span>
    <% end %>
  </td>

  <!-- Actions -->
  <td class="px-4 py-2 border space-x-2">

    <% if active_view.in?(["admin", "manager"]) %>

      <%= link_to "Edit",
          edit_task_path(task),
          class: "text-blue-600 hover:underline" %>

      <%= link_to "Delete",
          task_path(task),
          data: { turbo_method: :delete, turbo_confirm: "Delete this task?" },
          class: "text-red-600 hover:underline" %>

    <% end %>

    <% if active_view == "employee" && task.user == current_user %>

      <% if task.status != "completed" %>
        <%= link_to "Mark Complete",
            complete_task_path(task),
            data: { turbo_method: :patch },
            class: "text-green-600 hover:underline" %>
      <% end %>

    <% end %>

  </td>

</tr>
</turbo-frame>